{
  "_doc": "Example values for shared.auto.tfvars.json — copy to config/shared.auto.tfvars.json and fill in real values.",

  "backend_bucket": "my-terraform-state-bucket",
  "backend_key": "csoc-cluster/terraform.tfstate",
  "backend_region": "us-east-1",

  "region": "us-east-1",
  "aws_profile": "<AWS_PROFILE>",
  "csoc_account_id": "<CSOC_ACCOUNT_ID>",

  "cluster_name": "gen3-csoc-dev",
  "kubernetes_version": "1.35",
  "environment": "control-plane",
  "enable_automode": true,
  "enable_efs": false,
  "use_ack": true,
  "cluster_compute_config": {
    "enabled": true,
    "node_pools": ["general-purpose"]
  },
  "cluster_endpoint_public_access": true,
  "enable_cluster_creator_admin_permissions": true,

  "vpc_name": "gen3-kro-vpc",
  "vpc_cidr": "10.0.0.0/16",
  "enable_nat_gateway": true,
  "single_nat_gateway": true,
  "availability_zones": ["us-east-1a", "us-east-1b"],
  "private_subnet_cidrs": ["10.0.0.0/20", "10.0.16.0/20"],
  "public_subnet_cidrs": ["10.0.240.0/24", "10.0.241.0/24"],

  "git_org_name": "indiana-university",
  "gitops_addons_repo_name": "gen3-kro",
  "gitops_addons_repo_path": "bootstrap",
  "gitops_addons_repo_base_path": "argocd/",
  "gitops_addons_repo_revision": "main",
  "gitops_addons_github_url": "github.com",
  "gitops_addons_org_name": "indiana-university",

  "gitops_fleet_repo_name": "gen3-kro",
  "gitops_fleet_repo_path": "bootstrap",
  "gitops_fleet_repo_base_path": "argocd/",
  "gitops_fleet_repo_revision": "main",
  "gitops_fleet_github_url": "github.com",
  "gitops_fleet_org_name": "indiana-university",

  "argocd_namespace": "argocd",
  "argocd_chart_version": "<ARGOCD_CHART_VERSION>",
  "argocd_chart_repository": "https://argoproj.github.io/argo-helm",
  "argocd_values": {},

  "external_secrets_namespace": "external-secrets",
  "external_secrets_service_account": "external-secrets-sa",

  "ack_management_type": "self_managed",
  "kro_management_type": "self_managed",
  "argocd_management_type": "self_managed",
  "enable_ack_self_managed": true,
  "enable_ack_capability": false,
  "enable_argocd_self_managed": true,
  "enable_argocd_capability": false,
  "enable_kro_capability": false,
  "ack_namespace": "ack",

  "ssm_repo_secret_names": {
    "git-credentials": "<SSM_PATH_FOR_GIT_CREDENTIALS>"
  },

  "argocd_bootstrap_enabled": true,

  "addons": {
    "enable_external_secrets": true,
    "enable_kro_eks_rgs": true,
    "enable_multi_acct": true
  },

  "tags": {
    "Project": "eks-cluster-mgmt",
    "ManagedBy": "terraform",
    "Environment": "control-plane"
  },

  "spokes": [
    {
      "alias": "spoke1",
      "enabled": true,
      "provider": {
        "name": "aws",
        "aws_profile": "<SPOKE1_AWS_PROFILE>",
        "region": "us-east-1",
        "account_id": "<SPOKE1_ACCOUNT_ID>"
      }
    },
    {
      "alias": "spoke2",
      "enabled": true,
      "provider": {
        "name": "aws",
        "aws_profile": "<SPOKE2_AWS_PROFILE>",
        "region": "us-east-1",
        "account_id": "<SPOKE2_ACCOUNT_ID>"
      }
    }
  ],

  "developer_identity": {
    "iam_user_name": "<DEVELOPER_IAM_USER>",
    "role_name": "eks-cluster-mgmt-devcontainer",
    "mfa_device_name": "eks-cluster-mgmt-virtual-mfa",
    "create_virtual_mfa": true,
    "assume_requires_mfa": true,
    "attach_user_policy": true,
    "policy_filename": "gen3-test-developer.json",
    "role_max_session_duration": 43200
  },

  "iam_base_path": "iam"
}
