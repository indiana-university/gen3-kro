# ┌─────────────────────────────────────────┐
# │ 1. Git                                  │
# └─────────────────────────────────────────┘
.git/
**/.git/
# ┌─────────────────────────────────────────┐
# │ 2. IDE & Editor                         │
# └─────────────────────────────────────────┘
.vscode/
# ┌─────────────────────────────────────────┐
# │ 3. OS & Shell                           │
# └─────────────────────────────────────────┘
# macOS Finder
.DS_Store
# Linux/Mac temp
*/tmp/
*.tmp
crash.log
# shell environment overrides
**/.envrc
# ┌─────────────────────────────────────────┐
# │ 4. Logs & Session Captures              │
# └─────────────────────────────────────────┘
**/logs/*
**/*.log
/**/.bash_history
# terminal session recordings
**/*.crash.log
# ┌─────────────────────────────────────────┐
# │ 5. Secrets & Credentials                │
# └─────────────────────────────────────────┘
**/secrets/*
**/secrets.yaml
**/*.pem
**/*.ppk
**/*.tfvars
**/*.tfvars.json
**/*.auto.tfvars.json
**/variables.env
collected_files.txt
# ┌─────────────────────────────────────────┐
# │ 6. Terraform                            │
# └─────────────────────────────────────────┘
# Terraform state & plan
**/*.tfstate
**/*.tfstate.*
**/*.backup
**/tfplan
**/*.tfplan
**/*.tfplan.*
**/tfplan.*
**/plan.json
**/*.tfworkspace
**/.terraform/**
**/.terragrunt*/**
**/.terraform.lock.hcl
# override & lock files
**/override.tf
**/override.tf.json
**/*_override.tf
**/*_override.tf.json
**/.terraformrc
**/terraform.rc
**/backend.hcl
# ┌─────────────────────────────────────────┐
# │ 7. Application & Build Artifacts        │
# └─────────────────────────────────────────┘
**/outputs/**
**/output/**
# old files
**/old*/*
# ┌─────────────────────────────────────────┐
# │ 8. Miscellaneous                        │
# └─────────────────────────────────────────┘
# HCL: ignore backend config (contains account-specific values)
# All other .hcl files (terragrunt.hcl, terragrunt.stack.hcl) should be tracked.
**/*.lock.info

# Temporary output files
outputs.txt

# Generated shell scripts (local_file resources from Terraform)
**/connect-csoc.sh
**/port-forward.sh
terragrunt/**/*.sh
decoded-secret.json

# Scratch/working files
pending.md
docs/decisions-needed.md

# MCP server runtime config (generated by container-init.sh from .mcp/mcp.json)
**/mcp.json

# Config directory — real files ignored, examples & README tracked
config/*
!config/README.md
!config/*.example
!config/ssm-repo-secrets/
config/ssm-repo-secrets/*
!config/ssm-repo-secrets/*.example

# Generated script copies (container-init.sh places these in env dir)
terraform/env/aws/csoc-cluster/install.sh
terraform/env/aws/csoc-cluster/destroy.sh
.github/**
