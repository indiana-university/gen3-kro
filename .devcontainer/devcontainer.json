{
  "name": "eks-cluster-mgmt",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },

  // Use the standard devcontainers workspace path (repo is mounted under /workspaces/<repo>)
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",

  // Fix script permissions on the host before the workspace is mounted.
  // The workspace bind-mount preserves host file ownership (root in Codespaces),
  // and --security-opt=no-new-privileges blocks sudo inside the container.
  // Array form bypasses cmd.exe on Windows (which has a different `find` command)
  // and invokes bash directly (Git Bash on Windows, /bin/bash on Linux/Mac).
  // The || true ensures the container builds even if chmod is unavailable.
  "initializeCommand": ["bash", "-c", "find '${localWorkspaceFolder}/scripts' -name '*.sh' -exec chmod +x {} + 2>/dev/null || true"],

  // ── Credential mounts ────────────────────────────────────────────────
  // Mount ~/.aws from host so Terraform/AWS CLI picks up the pre-assumed credentials
  // written by scripts/mfa-session.sh (profile: csoc in ~/.aws/credentials).
  // ~/.kube is not mounted — connect-csoc.sh generates kubeconfig at runtime.
  "mounts": [
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.aws/eks-devcontainer,target=/home/vscode/.aws,type=bind,consistency=cached"
  ],

  "remoteUser": "vscode",

  // KUBECONFIG not set — uses default ~/.kube/config, written by connect-csoc.sh at runtime.
  // AWS_PROFILE selects the profile from the mounted ~/.aws/credentials file.
  // Run `bash scripts/mfa-session.sh <MFA_CODE>` on the host BEFORE starting the container.
  // The script writes temporary credentials to ~/.aws/credentials under [csoc].
  //
  // Credential tiers (validated by container-init.sh):
  //   Tier 1 (BEST):  MFA assumed-role — temporary, scoped, MFA-gated
  //   Tier 2 (OK):    Static IAM user — long-lived, broader access
  //   Tier 3/4:       Invalid/expired or missing — downstream stages blocked
  "containerEnv": {
    "REPO_ROOT":   "/workspaces/${localWorkspaceFolderBasename}",
    "AWS_PROFILE": "csoc"
  },

  // Orchestration flags: setup | init | apply | connect (blank = no-op)
  //   "setup"                      — env dirs, AWS cred validation, script copies
  //   "setup init"                 — + terraform init (via install.sh)
  //   "setup init apply"           — + terraform apply + connect (via install.sh)
  //   "setup connect"              — env setup + connect to existing cluster (no TF)
  //   "setup init apply connect"   — full pipeline + reconnect
  "postCreateCommand": "bash /workspaces/${localWorkspaceFolderBasename}/scripts/container-init.sh setup init apply connect",

  // Re-establish kubeconfig + ArgoCD port-forward on every container start.
  // postCreateCommand only runs once at container creation; this ensures the
  // port-forward survives container restarts and VS Code reconnects.
  "postStartCommand": "bash /workspaces/${localWorkspaceFolderBasename}/scripts/container-init.sh setup connect",

  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        // AI agents need unsandboxed terminal to run terraform/kubectl/helm/argocd
        "chat.tools.terminal.sandbox.enabled": false,
        "chat.instructionsFilesLocations": {
          ".github/instructions": true
        },
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true,
        "files.associations": {
          "*.hcl": "terragrunt"
        },
        "[yaml]": {
          "editor.defaultFormatter": "redhat.vscode-yaml"
        },
        "[terraform]": {
          "editor.defaultFormatter": "hashicorp.hcl"
        }
      },
      "extensions": [
        "hashicorp.hcl",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "redhat.vscode-yaml",
        "openai.chatgpt",
        "4ops.terraform",
        "github.copilot-chat"
      ]
    }
  },

  // ── Security hardening ───────────────────────────────────────────────
  // • No --privileged — no features require privileged mode
  // • No --network=host — use forwardPorts for ArgoCD UI instead (also
  //   fixes Docker Desktop on Windows where host networking doesn't work)
  // • --security-opt=no-new-privileges prevents SUID/SGID escalation
  "runArgs": [
    "--security-opt=no-new-privileges"
  ],

  // Forward ArgoCD port-forward (8080) from container → host.
  "forwardPorts": [8080],

  // ── Features ─────────────────────────────────────────────────────────
  // Docker CLI is not included — no scripts or modules use it.
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "installOhMyZsh": true,
      "upgradePackages": true
    },
    "ghcr.io/devcontainers/features/git:1": {
      "version": "latest"
    }
  }
}
